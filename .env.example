# Supabase — create project at https://supabase.com/
# Settings > API > Project URL and anon/public key
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Settings > API > service_role key (server-side only, never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Resend — create account at https://resend.com/
# API Keys > Create API key
RESEND_API_KEY=re_your_resend_api_key
# The "from" address — must be from a verified domain in Resend
# Use "onboarding@resend.dev" for testing before domain is set up
RESEND_FROM_EMAIL=Portfolio Contact <noreply@glennhudson.com>
# The address that receives contact form notifications
CONTACT_EMAIL=hello@glennhudson.com

# Site URL — update when live domain is ready
NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app
